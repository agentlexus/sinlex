# Скопируйте в secrets.env и заполните (файл secrets.env не коммитить в git)
# Путь по умолчанию: /opt/sinlex/secrets.env (переопределение: SINLEX_SECRETS_FILE)

# LLM (классика DS→PPLX sonar; углублённый PPLX sonar-reasoning-pro→DS — см. README.md)
SINLEX_PPLX_API_KEY=
SINLEX_DS_API_KEY=

# Углублённый анализ (гибрид): канал в config/hybrid_channel.json (email_logistics | max_suffler)
ENABLE_HYBRID_SUFFLER=0
HYBRID_CHANNEL_CONFIG=/opt/sinlex/config/hybrid_channel.json
SUFFLER_TIMEOUT_SECONDS=3600
SUFFLER_POLL_INTERVAL_SEC=15

# Email (канал email_logistics — см. docs/TZ-hybrid-email-logistics.md)
SUFFLER_EMAIL_TO=
SUFFLER_EMAIL_FROM=
SUFFLER_SMTP_HOST=
# mail.ru с VPS: 587/465 часто блокируются — используйте 2525 (STARTTLS)
SUFFLER_SMTP_PORT=2525
SUFFLER_SMTP_USER=
SUFFLER_SMTP_PASSWORD=
SUFFLER_SMTP_TLS=1
SUFFLER_IMAP_HOST=
SUFFLER_IMAP_PORT=993
SUFFLER_IMAP_USER=
SUFFLER_IMAP_PASSWORD=
SUFFLER_IMAP_FOLDER=INBOX
# SUFFLER_IMAP_PROCESSED_FOLDER=Sinlex/Done
# EMAIL_LOGISTICS_STATE_FILE=/opt/sinlex/data/email_logistics_state.json

# Max (legacy, только если active_channel=max_suffler в hybrid_channel.json)
MAX_SUFFLER_TOKEN=
MAX_SUFFLER_CHAT_ID=
# HYBRID_JOB_DIR — по умолчанию {project}/hybrid_jobs

# Регистрация на лендинге (отдельный ящик, не SUFFLER_*)
REGISTER_SMTP_HOST=mail.nic.ru
REGISTER_SMTP_PORT=465
REGISTER_SMTP_USER=register@sinlex.tech
REGISTER_SMTP_PASSWORD=
REGISTER_SMTP_TLS=1
REGISTER_FROM=register@sinlex.tech
REGISTER_FROM_NAME=Sinlex

# Размещение заказа → Google Таблица
ORDER_GOOGLE_SCRIPT_URL=

# Ops-уведомления в Max (те же MAX_SUFFLER_*)
ENABLE_OPS_NOTIFY=0
# OPS_MAX_CHAT_ID=  # опционально, иначе MAX_SUFFLER_CHAT_ID

# Таймауты server-side STEP/CAD (см. page_modules/upload_limits.py, docs/TZ-cad-nonblocking-api.md)
# SINLEX_STEP_ANALYZE_TIMEOUT=600
# SINLEX_STEP_GLB_TIMEOUT=300
# SINLEX_CAD_MAX_WORKERS=1

