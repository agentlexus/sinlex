# Скопируйте в .env и заполните (файл .env не коммитить в git)
# API-ключи и гибридный анализ — в secrets.env (шаблон: secrets.env.example)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Код НДС в чеке: 1 — без НДС, 2 — 0%, 4 — 20%
YOOKASSA_VAT_CODE=1
SINLEX_PUBLIC_URL=https://sinlex.tech/app
SINLEX_API_PUBLIC=https://sinlex.tech/api
SINLEX_API_KEY=
